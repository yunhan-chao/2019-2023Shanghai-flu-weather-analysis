library(tidyverse)
library(lubridate)
library(readxl)
library(worldmet)
# ---------- 1. 气象数据 ----------
sh_raw <- importNOAA(code = "583620-99999", year = 2019:2023)
sh_weekly <- sh_raw %>%
mutate(epi_week = floor_date(date, "week", week_start = 7)) %>%
group_by(epi_week) %>%
summarise(
avg_temp = mean(air_temp, na.rm = TRUE),
avg_rh   = mean(RH, na.rm = TRUE)
)
# ---------- 2. 流感数据 ----------
flu <- read_xlsx("data/raw/2019-2023年ILI流感周报.xlsx")
getwd()
